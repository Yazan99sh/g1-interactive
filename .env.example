# ==========================================================================
# G1 Interactive Voice Pipeline — environment configuration
# Copy this file to ".env" and fill in the real keys (the .env is gitignored).
# Keys are shared with the Altkamul "super-star" project.
# ==========================================================================

# ---- API keys -------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...
OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_API_KEY=AIza...
ELEVENLABS_API_KEY=sk_...
BRAVE_SEARCH_API_KEY=BSA...
# Optional: Groq key, only needed if STT_BACKEND=groq (faster Whisper transcription).
GROQ_API_KEY=gsk_...

# ---- LLM (thinking) -------------------------------------------------------
# Which provider is tried FIRST: openrouter (default) | openai | gemini. The other
# configured providers (whose key is set) stay as automatic fallbacks. Pick the
# provider+model from the panel's Models tab.
LLM_BACKEND=openrouter
# Stream the reply into speech sentence-by-sentence (lower perceived latency).
STREAMING_ENABLED=true
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_LLM_MODEL=gpt-4o-mini
# Google Gemini via its OpenAI-compatible endpoint (used when LLM_BACKEND=gemini;
# needs GEMINI_API_KEY above).
GEMINI_LLM_MODEL=gemini-3.1-flash-lite
LLM_TEMPERATURE=0.6
# 0 = no hard cap (recommended) so replies are never cut off mid-sentence.
# Control reply length via prompts/persona.md instead.
LLM_MAX_TOKENS=0

# ---- STT (listening) ------------------------------------------------------
# Transcription backend: openai (gpt-4o-transcribe, default) | groq (Whisper
# large-v3-turbo — much faster + cheaper, strong Arabic+English, needs GROQ_API_KEY).
# Falls back to OpenAI if the selected backend's key is missing. Pick in the Speech tab.
STT_BACKEND=openai
OPENAI_STT_MODEL=gpt-4o-transcribe
GROQ_STT_MODEL=whisper-large-v3-turbo

# ---- TTS (responding) -----------------------------------------------------
# ElevenLabs model id. Pick from the panel's Models tab: eleven_flash_v2_5 (ultra-low
# latency, default) | eleven_v3 (most expressive, higher latency) | eleven_turbo_v2_5 |
# eleven_multilingual_v2.
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=DANw8bnAVbjDEHwZIoYa
ELEVENLABS_ARABIC_VOICE_ID=DANw8bnAVbjDEHwZIoYa
# pcm_16000 => raw 16 kHz PCM straight to the robot speaker (no mp3 decode).
TTS_OUTPUT_FORMAT=pcm_16000
TTS_STABILITY=0.5
TTS_SIMILARITY=0.75
TTS_SPEED=1.0
# Chunked speech: split a long reply into small pieces and synth+play them one by one
# (prefetching the next while the current plays) so the robot starts talking almost
# instantly — no waiting. Toggle this + the piece size from the panel's Speech tab.
TTS_CHUNKING_ENABLED=true
TTS_CHUNK_MAX_CHARS=180

# ---- Audio / Voice-Activity-Detection -------------------------------------
SAMPLE_RATE=16000
SILENCE_RMS_THRESHOLD=500
SILENCE_DURATION_MS=900
MIN_RECORDING_MS=800
MAX_RECORDING_MS=15000
LISTEN_NO_SPEECH_TIMEOUT_MS=8000
STANDBY_WINDOW_MS=10000
# mic source: host (USB mic on the PC) | robot (G1 onboard mic over DDS)
MIC_SOURCE=host
MIC_DEVICE=
# audio sink: robot (G1 speaker over DDS) | host (PC speakers, for dev/testing)
AUDIO_SINK=robot

# ---- Wake word / standby --------------------------------------------------
WAKE_WORDS=hi robot,hey robot,hello robot,هاي روبوت,مرحبا روبوت
WAKE_ACK_TEXT_EN=Aha!
WAKE_ACK_TEXT_AR=أها!
# After this many consecutive silent listening turns, drop back to standby.
IDLE_AFTER_SILENT_TURNS=10
# Keep conversation memory across re-wakes if the last exchange was within this many
# seconds (same person continuing); start fresh after a longer gap. 0 = reset every wake.
SESSION_MEMORY_TIMEOUT_S=180
# Wake engine: stt (default; bilingual, small STT cost per phrase) | openwakeword
# (offline, no STT cost, phrase-only/English; needs `pip install openwakeword` + a
# model). Falls back to stt if openwakeword can't load.
WAKE_ENGINE=stt
# openWakeWord model: a built-in name (hey_jarvis, alexa, ...) or a path to a custom
# .onnx/.tflite trained for "Hi Robot". Built-ins do NOT match "Hi Robot".
OWW_MODEL=hey_jarvis
OWW_THRESHOLD=0.5
OWW_INFERENCE_FRAMEWORK=onnx

# ---- Idle command + listening hygiene -------------------------------------
# Saying "go idle / idle state / that's all / goodbye / نام / وضع الخمول" makes the
# robot acknowledge and drop back to STANDBY (waits for the wake word again).
IDLE_ANNOUNCE_EN=Okay, I'll be on standby. Say 'Hi robot' when you need me.
IDLE_ANNOUNCE_AR=تمام، رح أكون بوضع الانتظار. قول «هاي روبوت» لما تحتاجني.
# Ignore transcriptions shorter than this (treated as silence) so ambient noise and
# ASR hallucinations don't get "answered" — the robot then idles on its own.
NOISE_MIN_CHARS=3
# Extra phrases to treat as noise, on top of the built-in list ("you", "thanks for
# watching", "شكرا"…). Comma-separated.
NOISE_BLOCKLIST=
# Say one short line when a conversation ends by silence (so the visitor knows the
# robot disengaged). Set false to end silently.
CONVERSATION_END_ANNOUNCE=true
CONVERSATION_END_EN=I'll be right here if you need me.
CONVERSATION_END_AR=رح أكون هنا إذا احتجتني.

# ---- Robot / DDS ----------------------------------------------------------
ROBOT_ENABLED=true
DDS_DOMAIN=0
DDS_INTERFACE=ens37
ROBOT_SPEAKER_VOLUME=80
# Gap after each chunked speech piece (ms) covering DDS+playback-start latency so pieces
# don't overlap on the robot. Raise if pieces talk over each other; lower if gaps appear.
ROBOT_SPEAKER_TAIL_DRAIN_MS=200
# Audio is streamed to the robot in chunks over DDS. Smaller chunks transmit faster and
# more smoothly over a marginal (Wi-Fi) link and start sooner; larger chunks = fewer RPCs.
# 32000 B = 1.0 s @ 16k/16-bit/mono. If speech stutters ("voice drops then resumes"),
# the link is the bottleneck — prefer a WIRED connection to the robot; lowering this and
# ROBOT_SPEAKER_PACE can also help.
ROBOT_SPEAKER_CHUNK_BYTES=32000
# Feed pace: keep wall-clock at PACE× the audio sent, i.e. stay (1-PACE) ahead as a buffer
# cushion. 0.9 = 10% lead. Lower (e.g. 0.8) builds a bigger cushion against a jittery link
# (slightly longer initial buffering); 1.0 = no lead.
ROBOT_SPEAKER_PACE=0.9
ARM_GESTURES_ENABLED=true
# Safety: leave false and put the robot in Main mode (R1+X) + standing yourself.
ARM_ENTER_FSM=false
# Do ONE arm move when the robot starts talking, then hold it (not a loop).
TALK_GESTURES_ENABLED=true
# The single talking move (first id wins). Ids: 25 wave(face) 26 wave(high) 27 shake-hand
# 23 right-hand-up 33 hand-on-heart 17 clap 15 both-hands-up 18 high-five 22 refuse.
# Easiest to set from the control panel's Gestures tab. Confirm ids: tools/g1_list_actions.py
TALK_GESTURE_IDS=23
# Wake / meet-and-greet wave ("Aha!"). 25 = wave with the right hand up near the head.
WAKE_GESTURE_ID=25
# How long to hold the talking gesture before returning to rest, even if still
# speaking (clamped 1000-3000 ms). Short hold = looks deliberate, not frozen.
TALK_GESTURE_HOLD_MS=2000
# Experimental G1 onboard mic (raw PCM UDP multicast) — used only if MIC_SOURCE=robot
ROBOT_MIC_GROUP=239.168.123.161
ROBOT_MIC_PORT=5555
# Host's 192.168.123.x IP (the robot-facing NIC). Set this if MIC_SOURCE=robot.
ROBOT_MIC_IFACE_IP=

# ---- Head LED (state indicator) -------------------------------------------
# Colour the G1 head LED by state so you can read its state across the room. "R,G,B"
# 0-255. The head is blue by default, so standby stays blue (idle) and each active
# state gets a clearly different colour. Editable from the panel's Environment tab.
HEAD_LED_ENABLED=true
# calm blue (idle / normal — matches the head's default glow)
LED_STANDBY=0,0,90
# green (your turn — the mic is open)
LED_LISTENING=0,220,60
# amber (working)
LED_THINKING=255,120,0
# magenta (talking)
LED_SPEAKING=180,0,220
# red (a turn failed)
LED_ERROR=255,0,0
# States that breathe (smoothly pulse) instead of a solid colour. Comma-separated:
# standby/listening/thinking/speaking. Default = thinking (no audio plays then).
LED_PULSE_STATES=thinking
LED_PULSE_PERIOD_MS=1600

# ---- Dialogflow CX (optional "first answer" before the LLM) ---------------
# When enabled, each turn is sent to a Dialogflow CX agent FIRST; a confident intent
# match is spoken verbatim and the LLM is skipped. Anything it doesn't match falls
# through to the LLM. Defaults target the bilingual "Nova-1" agent. Toggle/tune + live-
# test from the panel's Dialogflow tab. Import the Q&A with tools/cx_import.py.
DIALOGFLOW_ENABLED=false
DIALOGFLOW_PROJECT=nova-1-474411
DIALOGFLOW_LOCATION=asia-south1
DIALOGFLOW_AGENT_ID=acada473-7777-4ae3-a27e-c0218644aaf5
# Path to the Google service-account JSON (runtime needs the "Dialogflow API Client"
# role; the import script tools/cx_import.py needs "Dialogflow API Admin"). Blank =
# use the GOOGLE_APPLICATION_CREDENTIALS env var instead.
DIALOGFLOW_KEY_PATH=
DIALOGFLOW_CONFIDENCE=0.6

# ---- Experimental: voice movement commands --------------------------------
# OFF by default. When on, "move forward/back/left/right", "turn left/right", "stop"
# (English or Arabic) drive the G1 a short, bounded distance via LocoClient. The robot
# MUST be standing in Main/Regular mode (R1+X) with clear space around it. Conservative
# speeds; experimental — test carefully. Toggle from the panel's Gestures tab.
MOVEMENT_COMMANDS_ENABLED=false
MOVE_SPEED=0.2
MOVE_YAW=0.4
MOVE_DURATION_S=1.5

# ---- Web search (Brave) ---------------------------------------------------
# When on (and BRAVE_SEARCH_API_KEY is set above), the robot searches the web for
# explicit "search / look it up" requests and for questions needing current info
# (news, weather, prices, recent events). It SAYS it's searching first, in the
# conversation language. Auto-off if BRAVE_SEARCH_API_KEY is empty.
WEB_SEARCH_ENABLED=true
WEB_SEARCH_COUNT=5
WEB_SEARCH_ANNOUNCE_EN=Sure, let me look that up online.
WEB_SEARCH_ANNOUNCE_AR=حسنًا، لحظة، خليني أبحث في الإنترنت.

# ---- Vision / peek (head camera) ------------------------------------------
# OFF by default. When on, "look at / show me / what do you see" (EN+AR) makes the robot
# grab one head-camera frame and DESCRIBE it out loud (the description is used only in the
# conversation — no photos saved).
#
# CAMERA_SOURCE picks how a frame is fetched:
#   dds  (default) — head RealSense is owned by the on-robot videohub service, which serves
#                    frames over DDS; we fetch via the SDK VideoClient (needs ROBOT_ENABLED +
#                    a reachable robot). No Jetson helper required. Recommended.
#   http           — tiny helper tools/jetson_camera_server.py ON the Jetson serves one JPEG
#                    over HTTP at CAMERA_SNAPSHOT_URL. NOTE: it opens /dev/video* directly,
#                    which collides with videohub ("device busy"); only works if videohub is
#                    stopped. Useful from the dev PC.
CAMERA_ENABLED=false
CAMERA_SOURCE=dds
CAMERA_SNAPSHOT_URL=http://192.168.123.164:8090/snapshot
CAMERA_TIMEOUT_S=6.0
PEEK_ENABLED=true
# Vision model for describing the frame. Blank = use the LLM endpoint's own model
# (gpt-4o-mini supports vision). Set e.g. gpt-4o for sharper scene understanding.
VISION_MODEL=
PEEK_ANNOUNCE_EN=Sure, let me take a look.
PEEK_ANNOUNCE_AR=حسنًا، خليني أشوف.

# ---- Robot brain / memory -------------------------------------------------
# Save a copy of every finished session to the host (brain/sessions + brain/logs).
# Works even with long-term memory off. Browse them in the panel's Memory tab.
MEMORY_SESSION_SNAPSHOTS=true
# Long-term memory ACROSS sessions (default OFF). When on, at session end an LLM extracts
# a few durable, mission-useful facts; teams & supervisors persist, ordinary visitors'
# details expire after MEMORY_VISITOR_TTL_DAYS. Relevant memories are recalled each turn.
LONG_TERM_MEMORY_ENABLED=false
# Where the brain lives (atomic fact files + index + snapshots). Gitignored; relative to
# the project root unless an absolute path.
BRAIN_DIR=brain
MEMORY_VISITOR_TTL_DAYS=7
MEMORY_FACT_TTL_DAYS=90
# Importance gate: drop extracted memories below this salience (unless team/supervisor).
MEMORY_SALIENCE_FLOOR=0.25
# How many memories to inject per turn (top-k by relevance + salience + recency).
MEMORY_RECALL_K=3

# ---- Knowledge base -------------------------------------------------------
# strict: if a KB question matches, speak the KB answer verbatim and skip the LLM
KB_STRICT=false

# ---- Control panel --------------------------------------------------------
# Optional shared token to protect the control panel API. If set, open the panel as
# http://<host>:8800/?token=YOURTOKEN. Leave blank for no auth (LAN-only — the panel
# can edit .env and run scripts, so only do that on the trusted robot LAN).
# PANEL_TOKEN=

# ---- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
