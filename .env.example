# ==========================================================================
# G1 Interactive Voice Pipeline — environment configuration
# Copy this file to ".env" and fill in the real keys (the .env is gitignored).
# Keys are shared with the Altkamul "super-star" project.
# ==========================================================================

# ---- API keys -------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...
OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_API_KEY=AIza...
ELEVENLABS_API_KEY=sk_...
BRAVE_SEARCH_API_KEY=BSA...

# ---- LLM (thinking) -------------------------------------------------------
# backend: openrouter (primary) | openai (fallback-only direct)
LLM_BACKEND=openrouter
# Stream the reply into speech sentence-by-sentence (lower perceived latency).
STREAMING_ENABLED=true
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.6
# 0 = no hard cap (recommended) so replies are never cut off mid-sentence.
# Control reply length via prompts/persona.md instead.
LLM_MAX_TOKENS=0

# ---- STT (listening) ------------------------------------------------------
OPENAI_STT_MODEL=gpt-4o-transcribe

# ---- TTS (responding) -----------------------------------------------------
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=DANw8bnAVbjDEHwZIoYa
ELEVENLABS_ARABIC_VOICE_ID=DANw8bnAVbjDEHwZIoYa
# pcm_16000 => raw 16 kHz PCM straight to the robot speaker (no mp3 decode).
TTS_OUTPUT_FORMAT=pcm_16000
TTS_STABILITY=0.5
TTS_SIMILARITY=0.75
TTS_SPEED=1.0
# Chunked speech: split a long reply into small pieces and synth+play them one by one
# (prefetching the next while the current plays) so the robot starts talking almost
# instantly — no waiting. Toggle this + the piece size from the panel's Speech tab.
TTS_CHUNKING_ENABLED=true
TTS_CHUNK_MAX_CHARS=180

# ---- Audio / Voice-Activity-Detection -------------------------------------
SAMPLE_RATE=16000
SILENCE_RMS_THRESHOLD=500
SILENCE_DURATION_MS=900
MIN_RECORDING_MS=800
MAX_RECORDING_MS=15000
LISTEN_NO_SPEECH_TIMEOUT_MS=8000
STANDBY_WINDOW_MS=10000
# mic source: host (USB mic on the PC) | robot (G1 onboard mic over DDS)
MIC_SOURCE=host
MIC_DEVICE=
# audio sink: robot (G1 speaker over DDS) | host (PC speakers, for dev/testing)
AUDIO_SINK=robot

# ---- Wake word / standby --------------------------------------------------
WAKE_WORDS=hi robot,hey robot,hello robot,hi go,هاي روبوت,مرحبا روبوت
WAKE_ACK_TEXT_EN=Aha!
WAKE_ACK_TEXT_AR=أها!
# After this many consecutive silent listening turns, drop back to standby.
IDLE_AFTER_SILENT_TURNS=10
# Keep conversation memory across re-wakes if the last exchange was within this many
# seconds (same person continuing); start fresh after a longer gap. 0 = reset every wake.
SESSION_MEMORY_TIMEOUT_S=180
# Wake engine: stt (default; bilingual, small STT cost per phrase) | openwakeword
# (offline, no STT cost, phrase-only/English; needs `pip install openwakeword` + a
# model). Falls back to stt if openwakeword can't load.
WAKE_ENGINE=stt
# openWakeWord model: a built-in name (hey_jarvis, alexa, ...) or a path to a custom
# .onnx/.tflite trained for "Hi Robot". Built-ins do NOT match "Hi Robot".
OWW_MODEL=hey_jarvis
OWW_THRESHOLD=0.5
OWW_INFERENCE_FRAMEWORK=onnx

# ---- Robot / DDS ----------------------------------------------------------
ROBOT_ENABLED=true
DDS_DOMAIN=0
DDS_INTERFACE=ens37
ROBOT_SPEAKER_VOLUME=80
ARM_GESTURES_ENABLED=true
# Safety: leave false and put the robot in Main mode (R1+X) + standing yourself.
ARM_ENTER_FSM=false
# Do ONE arm move when the robot starts talking, then hold it (not a loop).
TALK_GESTURES_ENABLED=true
# The single talking move (first id wins). Ids: 25 wave(face) 26 wave(high) 27 shake-hand
# 23 right-hand-up 33 hand-on-heart 17 clap 15 both-hands-up 18 high-five 22 refuse.
# Easiest to set from the control panel's Gestures tab. Confirm ids: tools/g1_list_actions.py
TALK_GESTURE_IDS=23
# Wake / meet-and-greet wave ("Aha!"). 25 = wave with the right hand up near the head.
WAKE_GESTURE_ID=25
# Experimental G1 onboard mic (raw PCM UDP multicast) — used only if MIC_SOURCE=robot
ROBOT_MIC_GROUP=239.168.123.161
ROBOT_MIC_PORT=5555
# Host's 192.168.123.x IP (the robot-facing NIC). Set this if MIC_SOURCE=robot.
ROBOT_MIC_IFACE_IP=

# ---- Head LED (state indicator) -------------------------------------------
# Colour the G1 head LED by state so you can read its state across the room. "R,G,B"
# 0-255. The head is blue by default, so standby stays blue (idle) and each active
# state gets a clearly different colour. Editable from the panel's Environment tab.
HEAD_LED_ENABLED=true
# calm blue (idle / normal — matches the head's default glow)
LED_STANDBY=0,0,90
# green (your turn — the mic is open)
LED_LISTENING=0,220,60
# amber (working)
LED_THINKING=255,120,0
# magenta (talking)
LED_SPEAKING=180,0,220
# red (a turn failed)
LED_ERROR=255,0,0
# States that breathe (smoothly pulse) instead of a solid colour. Comma-separated:
# standby/listening/thinking/speaking. Default = thinking (no audio plays then).
LED_PULSE_STATES=thinking
LED_PULSE_PERIOD_MS=1600

# ---- Knowledge base -------------------------------------------------------
# strict: if a KB question matches, speak the KB answer verbatim and skip the LLM
KB_STRICT=false

# ---- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
